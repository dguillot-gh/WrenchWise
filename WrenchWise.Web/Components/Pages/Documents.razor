@page "/documents"
@inject WebDataService Data
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Documents — WrenchWise</PageTitle>

<div class="d-flex align-center justify-space-between mb-6">
    <div>
        <MudText Typo="Typo.h5" Class="fw-bold">Vehicle Documents</MudText>
        <MudText Typo="Typo.body2" Class="opacity-60">Track your Insurance, Registration, and Inspections.</MudText>
    </div>
    @if (Data.IsLoaded)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => OpenEditor(null))" Class="rounded-lg">Add Document</MudButton>
    }
</div>

@if (!Data.IsLoaded)
{
    <MudGrid>
        @for (int i = 0; i < 3; i++)
        {
            <MudItem xs="12" md="6" lg="4">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Class="rounded-xl" />
            </MudItem>
        }
    </MudGrid>
}
else
{
    var documents = Data.Store!.VehicleDocuments.OrderByDescending(x => x.UpdatedUtc).ToList();
    if (!documents.Any())
    {
        <MudStack AlignItems="AlignItems.Center" Class="mt-12 opacity-50">
            <MudIcon Icon="@Icons.Material.Filled.Description" Style="font-size:4rem;" />
            <MudText Typo="Typo.h6">No documents yet</MudText>
            <MudText Typo="Typo.body2">Click "Add Document" to get started.</MudText>
        </MudStack>
    }
    else
    {
        <MudGrid Spacing="3">
            @foreach (var d in documents)
            {
                var vehicle = Data.Store!.Vehicles.FirstOrDefault(v => v.Id == d.VehicleId);
                var vehName = vehicle?.Nickname ?? "Unknown Vehicle";

                var isExpired = Data.IsDocumentExpired(d);
                var isExpiring = Data.IsDocumentExpiring(d);
                var statusColor = isExpired ? Color.Error : isExpiring ? Color.Warning : Color.Success;

                <MudItem xs="12" md="6" lg="4">
                    <MudCard Elevation="3" Class="rounded-xl h-100" Style="border: 1px solid var(--mud-palette-lines-default);">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar Color="Color.Primary" Variant="Variant.Filled">@vehName[0]</MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1" Class="fw-bold">@d.DocumentType</MudText>
                                <MudText Typo="Typo.caption" Class="opacity-60">@vehName</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudChip T="string" Color="statusColor" Size="Size.Small" Variant="Variant.Text">
                                    @(isExpired ? "Expired" : isExpiring ? "Expiring Soon" : "Active")
                                </MudChip>
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent Class="pt-0">
                            <div class="d-flex justify-space-between mb-2">
                                <MudText Typo="Typo.caption" Class="opacity-80">Provider/Policy</MudText>
                                <MudText Typo="Typo.body2" Class="fw-bold">@d.Provider @(string.IsNullOrEmpty(d.PolicyNumber) ? "" : $"# {d.PolicyNumber}")</MudText>
                            </div>
                            
                            @if (d.PremiumCost > 0)
                            {
                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.caption" Class="opacity-80">Premium Component</MudText>
                                    <MudText Typo="Typo.body2" Class="fw-bold text-success">@d.PremiumCost.ToString("C")</MudText>
                                </div>
                            }

                            <MudDivider Class="my-3"/>
                            
                            <div class="d-flex justify-space-between">
                                <div>
                                    <MudText Typo="Typo.caption" Class="opacity-60 d-block">Effective Date</MudText>
                                    <MudText Typo="Typo.body2">@(d.EffectiveDate?.ToString("d") ?? "—")</MudText>
                                </div>
                                <div class="text-end">
                                    <MudText Typo="Typo.caption" Class="opacity-60 d-block">Expiration Date</MudText>
                                    <MudText Typo="Typo.body2" Color="statusColor" Class="fw-bold">@(d.ExpirationDate?.ToString("d") ?? "—")</MudText>
                                </div>
                            </div>
                            
                            @if (!string.IsNullOrWhiteSpace(d.Notes))
                            {
                                <MudText Typo="Typo.caption" Class="d-block opacity-60 mt-2">Notes: @d.Notes</MudText>
                            }
                        </MudCardContent>
                        <MudCardActions Class="px-4 pb-3">
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Edit"
                                       OnClick="@(() => OpenEditor(d))">Edit</MudButton>
                            <MudSpacer />
                            <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" StartIcon="@Icons.Material.Filled.Delete"
                                       OnClick="@(() => ConfirmDelete(d))">Delete</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
}

@using WrenchWise.Shared.Models

@code {
    private async Task OpenEditor(VehicleDocument? existing)
    {
        var isNew = existing is null;
        var model = isNew
            ? new VehicleDocument
            {
                VehicleId = Data.Store?.Vehicles.FirstOrDefault()?.Id ?? Guid.Empty
            }
            : new VehicleDocument
            {
                Id = existing!.Id,
                VehicleId = existing.VehicleId,
                DocumentType = existing.DocumentType,
                Provider = existing.Provider,
                PolicyNumber = existing.PolicyNumber,
                EffectiveDate = existing.EffectiveDate,
                ExpirationDate = existing.ExpirationDate,
                PremiumCost = existing.PremiumCost,
                Notes = existing.Notes
            };

        var parameters = new DialogParameters<DocumentDialog>
        {
            { x => x.Model, model },
            { x => x.IsNew, isNew },
            { x => x.Vehicles, Data.Store?.Vehicles ?? new() }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<DocumentDialog>(isNew ? "Add Document" : "Edit Document", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            var saved = await Data.SaveDocumentAsync(model);
            Snackbar.Add(saved ? "Document saved!" : "Failed to save.", saved ? Severity.Success : Severity.Error);
        }
    }

    private async Task ConfirmDelete(VehicleDocument doc)
    {
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Delete Document",
            new DialogParameters<MudMessageBox>
            {
                { x => x.Message, $"Delete \"{doc.DocumentType}\" document?" },
                { x => x.YesText, "Delete" },
                { x => x.CancelText, "Cancel" }
            });
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            var deleted = await Data.DeleteDocumentAsync(doc.Id);
            Snackbar.Add(deleted ? "Document deleted." : "Failed to delete.", deleted ? Severity.Success : Severity.Error);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Data.Changed += StateHasChanged;
        await Data.InitializeAsync();
    }

    public void Dispose() => Data.Changed -= StateHasChanged;
}
