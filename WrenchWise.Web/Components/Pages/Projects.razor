@page "/projects"
@inject WebDataService Data
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Projects — WrenchWise</PageTitle>

<div class="d-flex align-center justify-space-between mb-6">
    <div>
        <MudText Typo="Typo.h5" Class="fw-bold">Vehicle Projects</MudText>
        <MudText Typo="Typo.body2" Class="opacity-60">Plan and track your major upgrades & repairs.</MudText>
    </div>
    @if (Data.IsLoaded)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => OpenEditor(null))" Class="rounded-lg">Add Project</MudButton>
    }
</div>

@if (!Data.IsLoaded)
{
    <MudGrid>
        @for (int i = 0; i < 3; i++)
        {
            <MudItem xs="12" md="6" lg="4">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Class="rounded-xl" />
            </MudItem>
        }
    </MudGrid>
}
else
{
    var projects = Data.Store!.VehicleProjects.OrderByDescending(x => x.UpdatedUtc).ToList();
    if (!projects.Any())
    {
        <MudStack AlignItems="AlignItems.Center" Class="mt-12 opacity-50">
            <MudIcon Icon="@Icons.Material.Filled.Engineering" Style="font-size:4rem;" />
            <MudText Typo="Typo.h6">No projects yet</MudText>
            <MudText Typo="Typo.body2">Click "Add Project" to create one.</MudText>
        </MudStack>
    }
    else
    {
        <MudGrid Spacing="3">
            @foreach (var p in projects)
            {
                var vehicle = Data.Store!.Vehicles.FirstOrDefault(v => v.Id == p.VehicleId);
                var vehName = vehicle?.Nickname ?? "Unknown Vehicle";

                <MudItem xs="12" md="6" lg="4">
                    <MudCard Elevation="3" Class="rounded-xl h-100" Style="border: 1px solid var(--mud-palette-lines-default);">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar Color="Color.Primary" Variant="Variant.Filled">@vehName[0]</MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1" Class="fw-bold">@p.Title</MudText>
                                <MudText Typo="Typo.caption" Class="opacity-60">@vehName</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudChip T="string" Color="GetStatusColor(p.Status)" Size="Size.Small" Variant="Variant.Text">@p.Status</MudChip>
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent Class="pt-0">
                            <MudText Typo="Typo.body2" Class="mb-3 opacity-80" Style="min-height: 40px;">@p.Description</MudText>
                            
                            <div class="d-flex justify-space-between mb-1">
                                <MudText Typo="Typo.caption">Estimated</MudText>
                                <MudText Typo="Typo.caption">Actual</MudText>
                            </div>
                            <div class="d-flex justify-space-between">
                                <MudText Typo="Typo.body2" Class="fw-bold text-warning">@p.EstimatedCost.ToString("C")</MudText>
                                <MudText Typo="Typo.body2" Class="@($"fw-bold {(p.ActualCost > p.EstimatedCost ? "text-error" : "text-success")}")">
                                    @(p.ActualCost > 0 ? p.ActualCost.ToString("C") : "—")
                                </MudText>
                            </div>
                            
                            @if (p.TargetDate.HasValue)
                            {
                                <MudDivider Class="my-3"/>
                                <div class="d-flex align-center gap-2">
                                    <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Class="opacity-60" />
                                    <MudText Typo="Typo.caption" Class="opacity-80">Target: @p.TargetDate.Value.ToString("d")</MudText>
                                </div>
                            }
                        </MudCardContent>
                        <MudCardActions Class="px-4 pb-3">
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Edit"
                                       OnClick="@(() => OpenEditor(p))">Edit</MudButton>
                            <MudSpacer />
                            <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" StartIcon="@Icons.Material.Filled.Delete"
                                       OnClick="@(() => ConfirmDelete(p))">Delete</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
}

@using WrenchWise.Shared.Models

@code {
    private async Task OpenEditor(VehicleProject? existing)
    {
        var isNew = existing is null;
        var model = isNew
            ? new VehicleProject
            {
                VehicleId = Data.Store?.Vehicles.FirstOrDefault()?.Id ?? Guid.Empty
            }
            : new VehicleProject
            {
                Id = existing!.Id,
                VehicleId = existing.VehicleId,
                Title = existing.Title,
                Description = existing.Description,
                EstimatedCost = existing.EstimatedCost,
                ActualCost = existing.ActualCost,
                TargetDate = existing.TargetDate,
                Status = existing.Status
            };

        var parameters = new DialogParameters<ProjectDialog>
        {
            { x => x.Model, model },
            { x => x.IsNew, isNew },
            { x => x.Vehicles, Data.Store?.Vehicles ?? new() }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<ProjectDialog>(isNew ? "Add Project" : "Edit Project", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            var saved = await Data.SaveProjectAsync(model);
            Snackbar.Add(saved ? "Project saved!" : "Failed to save.", saved ? Severity.Success : Severity.Error);
        }
    }

    private async Task ConfirmDelete(VehicleProject project)
    {
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Delete Project",
            new DialogParameters<MudMessageBox>
            {
                { x => x.Message, $"Delete project \"{project.Title}\"?" },
                { x => x.YesText, "Delete" },
                { x => x.CancelText, "Cancel" }
            });
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            var deleted = await Data.DeleteProjectAsync(project.Id);
            Snackbar.Add(deleted ? "Project deleted." : "Failed to delete.", deleted ? Severity.Success : Severity.Error);
        }
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Planning" => Color.Warning,
        "InProgress" => Color.Info,
        "Completed" => Color.Success,
        _ => Color.Default
    };

    protected override async Task OnInitializedAsync()
    {
        Data.Changed += StateHasChanged;
        await Data.InitializeAsync();
    }

    public void Dispose() => Data.Changed -= StateHasChanged;
}
