@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Surface" Class="px-4">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        <MudText Typo="Typo.h6" Class="fw-bold ms-2" Color="Color.Primary">WrenchWise</MudText>
        <MudText Typo="Typo.body2" Class="opacity-40 ms-1 d-none d-sm-block">Fleet Dashboard</MudText>
        <MudSpacer />
        <MudTooltip Text="Export Data to CSV">
            <MudIconButton Icon="@Icons.Material.Filled.Download" Color="Color.Inherit" OnClick="@ExportCsvAsync" />
        </MudTooltip>
        <MudTooltip Text="Refresh data">
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Inherit" OnClick="@RefreshAsync" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always" Color="Color.Surface">
        <MudDrawerHeader Class="py-5 px-4">
            <div class="d-flex align-center gap-3">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium">W</MudAvatar>
                <div>
                    <MudText Typo="Typo.subtitle2" Class="fw-bold">WrenchWise</MudText>
                    <MudText Typo="Typo.caption" Class="opacity-50">Fleet Management</MudText>
                </div>
            </div>
        </MudDrawerHeader>
        <MudDivider />
        <MudNavMenu Class="pa-2">
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                Dashboard
            </MudNavLink>
            <MudNavLink Href="/fleet" Icon="@Icons.Material.Filled.DirectionsCar">
                Fleet
            </MudNavLink>
            <MudNavLink Href="/maintenance" Icon="@Icons.Material.Filled.Build">
                Maintenance
            </MudNavLink>
            <MudNavLink Href="/fuel" Icon="@Icons.Material.Filled.LocalGasStation">
                Fuel Log
            </MudNavLink>
            <MudNavLink Href="/reminders" Icon="@Icons.Material.Filled.NotificationsActive">
                Reminders
            </MudNavLink>
            <MudNavLink Href="/projects" Icon="@Icons.Material.Filled.Engineering">
                Projects
            </MudNavLink>
            <MudNavLink Href="/documents" Icon="@Icons.Material.Filled.Description">
                Documents
            </MudNavLink>
            <MudNavLink Href="/report" Icon="@Icons.Material.Filled.Print">
                Printable Report
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6 px-4 px-sm-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    [Inject] private WebDataService Data { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private async Task RefreshAsync()
    {
        await Data.RefreshAsync();
    }

    private async Task ExportCsvAsync()
    {
        if (Data.Store is null) return;
        var csv = WrenchWise.Shared.Export.CsvExporter.ExportStoreToCsv(Data.Store);
        var filename = $"wrenchwise-export-{DateTime.UtcNow:yyyyMMdd}.csv";
        await JS.InvokeVoidAsync("downloadFileFromText", filename, csv);
    }

    private MudTheme _theme = new MudTheme()
    {
        PaletteDark = new PaletteDark()
        {
            Primary = "#38BDF8",   // Crisp Sky Blue for perfect contrast
            Secondary = "#0EA5E9", // Slightly deeper sky blue for accents
            Info = "#10B981",      // Emerald Green (Fuel)
            Warning = "#F59E0B",   // Amber (Services)
            Error = "#EF4444",     // Red (Errors / Pending)
            Success = "#10B981",   // Emerald Green
            Background = "#121212", // Pure Neutral Dark
            Surface = "#1e1e1e",    // Pure Neutral Surface
            AppbarBackground = "#1e1e1e",
            DrawerBackground = "#1e1e1e",
            TextPrimary = "#e6edf3",
            TextSecondary = "#9eb0c4",
            ActionDefault = "#9eb0c4",
            ActionDisabled = "#1e2e3e",
            Divider = "#1e2e3e"
        }
    };
}
