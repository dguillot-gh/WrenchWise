@page "/quick-add"

<PageTitle>Quick Add</PageTitle>
<h1>Quick Add</h1>
<p>Fast one-tap entry paths.</p>

<div class="row g-3">
    <div class="col-6">
        <a class="card p-3 text-decoration-none" href="fuel">
            <h4>Fuel Fill-up</h4>
            <div class="text-muted">Log gallons, cost, and quality notes.</div>
        </a>
    </div>
    <div class="col-6">
        <a class="card p-3 text-decoration-none" href="maintenance?preset=Oil%20Change">
            <h4>Oil Change</h4>
            <div class="text-muted">Maintenance form pre-filled.</div>
        </a>
    </div>
    <div class="col-6">
        <a class="card p-3 text-decoration-none" href="maintenance?preset=Tire%20Rotation">
            <h4>Tire Rotation</h4>
            <div class="text-muted">Preset with one tap.</div>
        </a>
    </div>
    <div class="col-6">
        <a class="card p-3 text-decoration-none" href="reminders">
            <h4>Reminder</h4>
            <div class="text-muted">Add the next service reminder.</div>
        </a>
    </div>
    <div class="col-6">
        <a class="card p-3 text-decoration-none" href="trip-mode">
            <h4>Trip Mode</h4>
            <div class="text-muted">Start trip logging with quick fuel/expense entries.</div>
        </a>
    </div>
    <div class="col-6">
        <a class="card p-3 text-decoration-none" href="timeline">
            <h4>Timeline</h4>
            <div class="text-muted">View all events in one ordered feed.</div>
        </a>
    </div>
</div>
