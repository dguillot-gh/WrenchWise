@page "/settings"
@inject WrenchWiseService WrenchWise

<PageTitle>Settings</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Settings</MudText>

<MudCard Elevation="1" Class="mb-4">
    <MudCardHeader>
        <CardHeaderContent>
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Storage" Class="mr-2 opacity-60" />
                <MudText Typo="Typo.subtitle1">Server Configuration</MudText>
            </div>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent Class="pt-0">
        <MudStack Spacing="3">
            <MudTextField Label="Server Base URL"
                          Value="@WrenchWise.ApiBaseUrl"
                          ValueChanged="@(async (string url) => await WrenchWise.SetApiBaseUrlAsync(url))"
                          T="string"
                          Variant="Variant.Outlined"
                          HelperText="Enter the URL (e.g. http://192.168.1.50:18080) of your backend instance."
                          Margin="Margin.Dense" />
        </MudStack>
    </MudCardContent>
</MudCard>

<MudStack AlignItems="AlignItems.Center" Spacing="1" Class="mt-12 mb-8 opacity-40">
    <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Large" />
    <MudText Typo="Typo.subtitle2" Style="font-weight: 700;">WrenchWise Mobile</MudText>
    <MudText Typo="Typo.caption">Version 1.0.0 (Production)</MudText>
</MudStack>

@code {
    protected override async Task OnInitializedAsync()
    {
        await WrenchWise.InitializeAsync();
    }
}
