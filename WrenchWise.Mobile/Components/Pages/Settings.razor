@page "/settings"
@inject WrenchWiseService WrenchWise
@inject ISnackbar Snackbar

<PageTitle>Settings</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Settings</MudText>

<MudCard Elevation="1" Class="mb-4">
    <MudCardHeader>
        <CardHeaderContent>
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Storage" Class="mr-2 opacity-60" />
                <MudText Typo="Typo.subtitle1">Server Configuration</MudText>
            </div>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent Class="pt-0">
        <MudStack Spacing="3">
            <MudTextField Label="Server Base URL"
                          @bind-Value="_url"
                          T="string"
                          Variant="Variant.Outlined"
                          HelperText="Enter the URL (e.g. http://192.168.1.50:18080) of your backend instance."
                          Margin="Margin.Dense" />
            
            <div class="d-flex align-center mt-1">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="SaveAndTestAsync" Class="mr-4">
                    Save & Test
                </MudButton>
                
                @if (_isTesting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <MudText Typo="Typo.body2">Checking...</MudText>
                }
                else if (_connectionSuccess.HasValue)
                {
                    if (_connectionSuccess.Value)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Class="mr-2" />
                        <MudText Typo="Typo.body2" Color="Color.Success">Connected</MudText>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Class="mr-2" />
                        <MudText Typo="Typo.body2" Color="Color.Error">Connection Failed</MudText>
                    }
                }
            </div>
        </MudStack>
    </MudCardContent>
</MudCard>

<MudCard Elevation="1" Class="mb-4">
    <MudCardHeader>
        <CardHeaderContent>
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Backup" Class="mr-2 opacity-60" />
                <MudText Typo="Typo.subtitle1">Data Backup & Restore</MudText>
            </div>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent Class="pt-0">
        <MudText Typo="Typo.body2" Class="mb-4 opacity-70">
            Use CSV to migrate from other apps or export to spreadsheets. A Full JSON Backup saves an exact digital copy of your entire WrenchWise offline database.
        </MudText>
        <MudStack Spacing="2">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.UploadFile" OnClick="ImportCsvAsync">Import CSV Logs</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Surface" StartIcon="@Icons.Material.Filled.InsertDriveFile" OnClick="ExportCsvAsync">Export CSV (Excel/Sheets)</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Download" OnClick="ExportJsonAsync">Export Complete JSON Backup</MudButton>
        </MudStack>
    </MudCardContent>
</MudCard>

<MudCard Elevation="1" Class="mb-4">
    <MudCardHeader>
        <CardHeaderContent>
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Email" Class="mr-2 opacity-60" />
                <MudText Typo="Typo.subtitle1">Email Reports</MudText>
            </div>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent Class="pt-0">
        <MudText Typo="Typo.body2" Class="mb-4 opacity-70">
            Send maintenance and fuel summaries to your configured email. Requires the backend server to be running.
        </MudText>
        <MudStack Spacing="2">
            <div class="d-flex align-center">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.CalendarViewWeek" OnClick="@(() => SendReportAsync("weekly", "Weekly"))"
                           Disabled="_isSendingReport" Style="min-width: 180px;">
                    Weekly Report
                </MudButton>
                <MudText Typo="Typo.caption" Class="ml-3 opacity-50">Last 7 days</MudText>
            </div>
            <div class="d-flex align-center">
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.CalendarMonth" OnClick="@(() => SendReportAsync("monthly", "Monthly"))"
                           Disabled="_isSendingReport" Style="min-width: 180px;">
                    Monthly Report
                </MudButton>
                <MudText Typo="Typo.caption" Class="ml-3 opacity-50">Last 30 days</MudText>
            </div>
            <div class="d-flex align-center">
                <MudButton Variant="Variant.Filled" Color="Color.Info" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.CalendarToday" OnClick="@(() => SendReportAsync("yearly", "Yearly"))"
                           Disabled="_isSendingReport" Style="min-width: 180px;">
                    Yearly Report
                </MudButton>
                <MudText Typo="Typo.caption" Class="ml-3 opacity-50">Last 12 months</MudText>
            </div>
            <MudDivider Class="my-1" />
            <div class="d-flex align-center">
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.AdminPanelSettings" OnClick="@(() => SendReportAsync("admin", "Admin"))"
                           Disabled="_isSendingReport" Style="min-width: 180px;">
                    Admin Report
                </MudButton>
                <MudText Typo="Typo.caption" Class="ml-3 opacity-50">All-time, grouped by vehicle</MudText>
            </div>
        </MudStack>
        @if (_isSendingReport)
        {
            <div class="d-flex align-center mt-2">
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <MudText Typo="Typo.caption">Sending @_activeReportType report...</MudText>
            </div>
        }
    </MudCardContent>
</MudCard>

<MudCard Elevation="1" Class="mb-4">
    <MudCardHeader>
        <CardHeaderContent>
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2 opacity-60" />
                <MudText Typo="Typo.subtitle1">About WrenchWise</MudText>
            </div>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent Class="pt-0">
        <MudText Typo="Typo.body2" Class="mb-2 opacity-70">
            WrenchWise is a personal vehicle maintenance tracker designed to keep all your automotive records organized in one place — offline-first with optional cloud sync.
        </MudText>

        <MudText Typo="Typo.subtitle2" Class="mt-4 mb-1" Style="font-weight: 700;">Features</MudText>
        <MudStack Spacing="0">
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; Multi-vehicle garage management</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; Service & maintenance record tracking with parts</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; Fuel log with MPG calculations & receipt OCR</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; Tire tracking with rotation history</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; Service reminders & scheduling</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; Project planning with cost estimates</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; Document vault for insurance, registration & receipts</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; File attachment support for invoices & receipts</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; Offline-first with queued sync to backend</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; CSV import/export & full JSON backup</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; Weekly email reports</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; In-app activity log</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; Web dashboard companion app</MudText>
        </MudStack>

        <MudText Typo="Typo.subtitle2" Class="mt-4 mb-1" Style="font-weight: 700;">Tech Stack</MudText>
        <MudStack Spacing="0">
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; <b>Mobile</b> — .NET MAUI Blazor Hybrid (Android, iOS, Windows)</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; <b>Web</b> — Blazor Server (ASP.NET Core)</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; <b>Backend</b> — ASP.NET Core Minimal API</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; <b>Database</b> — PostgreSQL with EF Core</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; <b>UI</b> — MudBlazor component library</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; <b>Storage</b> — Local JSON (offline) + PostgreSQL (cloud)</MudText>
            <MudText Typo="Typo.body2" Class="opacity-80">&#8226; <b>Hosting</b> — Docker (self-hosted)</MudText>
        </MudStack>

        <MudDivider Class="my-4" />
        <MudStack AlignItems="AlignItems.Center" Spacing="1" Class="opacity-50">
            <MudText Typo="Typo.subtitle2" Style="font-weight: 700;">WrenchWise Mobile</MudText>
            <MudText Typo="Typo.caption">Version @Microsoft.Maui.ApplicationModel.AppInfo.Current.VersionString (Build @Microsoft.Maui.ApplicationModel.AppInfo.Current.BuildString)</MudText>
        </MudStack>
    </MudCardContent>
</MudCard>

@code {
    private string _url = "";
    private bool _isTesting;
    private bool? _connectionSuccess;
    private bool _isSendingReport;
    private string _activeReportType = "";

    protected override async Task OnInitializedAsync()
    {
        await WrenchWise.InitializeAsync();
        _url = WrenchWise.ApiBaseUrl;
    }

    private async Task SaveAndTestAsync()
    {
        _isTesting = true;
        _connectionSuccess = null;
        StateHasChanged();

        await WrenchWise.SetApiBaseUrlAsync(_url);
        _connectionSuccess = await WrenchWise.CheckConnectionAsync();

        _isTesting = false;
        StateHasChanged();
    }

    private async Task ImportCsvAsync()
    {
        var result = await WrenchWise.ImportFromCsvAsync();
        if (result.Success)
            Snackbar.Add(result.Message, Severity.Success);
        else
            Snackbar.Add(result.Message, Severity.Error);
    }

    private async Task ExportCsvAsync()
    {
        var path = await WrenchWise.ExportCsvAsync();
        if (!string.IsNullOrEmpty(path))
        {
            await Microsoft.Maui.ApplicationModel.DataTransfer.Share.Default.RequestAsync(new Microsoft.Maui.ApplicationModel.DataTransfer.ShareFileRequest
            {
                Title = "WrenchWise CSV Data",
                File = new Microsoft.Maui.ApplicationModel.DataTransfer.ShareFile(path)
            });
        }
    }

    private async Task ExportJsonAsync()
    {
        var path = await WrenchWise.ExportJsonBackupAsync();
        if (!string.IsNullOrEmpty(path))
        {
            await Microsoft.Maui.ApplicationModel.DataTransfer.Share.Default.RequestAsync(new Microsoft.Maui.ApplicationModel.DataTransfer.ShareFileRequest
            {
                Title = "WrenchWise Full Backup",
                File = new Microsoft.Maui.ApplicationModel.DataTransfer.ShareFile(path)
            });
        }
    }

    private async Task SendReportAsync(string slug, string displayName)
    {
        if (string.IsNullOrWhiteSpace(WrenchWise.ApiBaseUrl))
        {
            Snackbar.Add("Set the server URL first.", Severity.Warning);
            return;
        }

        _isSendingReport = true;
        _activeReportType = displayName;
        StateHasChanged();

        try
        {
            using var client = new HttpClient { Timeout = TimeSpan.FromSeconds(60) };
            var endpoint = $"{WrenchWise.ApiBaseUrl.TrimEnd('/')}/api/report/{slug}/email";
            var response = await client.PostAsync(endpoint, null);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"{displayName} report sent to your email!", Severity.Success);
            }
            else
            {
                try
                {
                    var body = await response.Content.ReadAsStringAsync();
                    var json = System.Text.Json.JsonDocument.Parse(body);
                    var msg = json.RootElement.GetProperty("message").GetString();
                    Snackbar.Add(msg ?? body, Severity.Error);
                }
                catch
                {
                    Snackbar.Add($"Server returned {(int)response.StatusCode}", Severity.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSendingReport = false;
            StateHasChanged();
        }
    }
}
