@page "/sync"
@implements IDisposable
@inject WrenchWiseService WrenchWise

<PageTitle>Sync</PageTitle>
<h1>Sync Settings</h1>
<p>This app logs data locally first. Sync when you have connectivity to your home server.</p>

<div class="card p-3 mb-3">
    <label class="form-label">Backend API URL</label>
    <input class="form-control mb-2" @bind="_apiUrl" placeholder="http://192.168.x.x:18080" />
    <small class="text-muted">Use your Tailscale IP or local LAN IP where Docker is running.</small>
    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-outline-primary" @onclick="SaveApiUrlAsync">Save URL</button>
        <button class="btn btn-primary" @onclick="RunSyncAsync" disabled="@_syncing">Sync Now</button>
    </div>
</div>

<div class="card p-3">
    <div>Pending operations: <strong>@WrenchWise.PendingSyncCount</strong></div>
    <div>Last sync: <strong>@(WrenchWise.LastSyncUtc?.ToLocalTime().ToString("f") ?? "Never")</strong></div>
    <div class="mt-3 d-flex gap-2 flex-wrap">
        <button class="btn btn-outline-primary" @onclick="ExportJsonAsync">Export JSON Backup</button>
        <button class="btn btn-outline-primary" @onclick="ExportCsvAsync">Export CSV Backup</button>
    </div>
    <div class="mt-3 d-flex gap-2 flex-wrap">
        <button class="btn btn-outline-secondary" @onclick="ImportJsonAsync">Import JSON Backup</button>
        <button class="btn btn-outline-secondary" @onclick="ImportCsvAsync">Import CSV</button>
    </div>
    <small class="text-muted d-block mt-2">
        Import replaces/merges local data and queues it for next sync.
    </small>
    @if (!string.IsNullOrWhiteSpace(_backupPath))
    {
        <div class="mt-2 text-muted">Backup file: @_backupPath</div>
    }
    @if (!string.IsNullOrWhiteSpace(_status))
    {
        <div class="mt-2 alert @(_error ? "alert-danger" : "alert-success")">@_status</div>
    }
</div>

@code {
    private string _apiUrl = string.Empty;
    private string _status = string.Empty;
    private string _backupPath = string.Empty;
    private bool _syncing;
    private bool _error;

    protected override async Task OnInitializedAsync()
    {
        await WrenchWise.InitializeAsync();
        WrenchWise.Changed += HandleChanged;
        _apiUrl = WrenchWise.ApiBaseUrl;
    }

    private async Task SaveApiUrlAsync()
    {
        await WrenchWise.SetApiBaseUrlAsync(_apiUrl);
        _status = "API URL saved.";
        _error = false;
    }

    private async Task RunSyncAsync()
    {
        _syncing = true;
        _status = string.Empty;
        _error = false;
        try
        {
            await WrenchWise.SetApiBaseUrlAsync(_apiUrl);
            await WrenchWise.SyncNowAsync();
            _status = "Sync completed.";
        }
        catch (Exception ex)
        {
            _status = ex.Message;
            _error = true;
        }
        finally
        {
            _syncing = false;
        }
    }

    private async Task ExportJsonAsync()
    {
        _backupPath = await WrenchWise.ExportJsonBackupAsync();
        _status = "JSON backup exported.";
        _error = false;
    }

    private async Task ExportCsvAsync()
    {
        _backupPath = await WrenchWise.ExportCsvBackupAsync();
        _status = "CSV backup exported.";
        _error = false;
    }

    private async Task ImportJsonAsync()
    {
        var result = await WrenchWise.ImportFromJsonAsync();
        _status = result.Message;
        _error = !result.Success;
    }

    private async Task ImportCsvAsync()
    {
        var result = await WrenchWise.ImportFromCsvAsync();
        _status = result.Message;
        _error = !result.Success;
    }

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => WrenchWise.Changed -= HandleChanged;
}
