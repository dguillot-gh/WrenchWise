@page "/sync"
@implements IDisposable
@inject WrenchWiseService WrenchWise

<PageTitle>Sync to Cloud</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Sync to Server</MudText>

<MudPaper Class="pa-6 mb-4 d-flex flex-column align-center" Elevation="1">
    @if (WrenchWise.PendingSyncCount > 0)
    {
        <MudAvatar Color="Color.Warning" Variant="Variant.Filled" Style="height:70px; width:70px;" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Sync" Size="Size.Large" />
        </MudAvatar>

        <MudText Typo="Typo.h6" Align="Align.Center">@WrenchWise.PendingSyncCount Pending Edits</MudText>
        <MudText Typo="Typo.body2" Align="Align.Center" Class="opacity-60 mb-6">
            Your pending changes are saved offline and waiting to be synced to your WrenchWise Server.
        </MudText>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   FullWidth="true"
                   OnClick="AttemptSyncAsync"
                   Disabled="@_isSyncing"
                   StartIcon="@(_isSyncing ? null : Icons.Material.Filled.CloudUpload)"
                   Class="rounded-pill py-3">
            @if (_isSyncing)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
                <span>Syncing...</span>
            }
            else
            {
                <span>Sync Now</span>
            }
        </MudButton>
    }
    else
    {
        <MudAvatar Color="Color.Success" Variant="Variant.Filled" Style="height:70px; width:70px;" Class="mb-4">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" />
        </MudAvatar>

        <MudText Typo="Typo.h6" Align="Align.Center">All Synced up!</MudText>
        <MudText Typo="Typo.body2" Align="Align.Center" Class="opacity-60">
            Your local offline database is fully synced to your WrenchWise server.
        </MudText>
    }

    @if (!string.IsNullOrEmpty(_syncError))
    {
        <MudAlert Severity="Severity.Error" Class="mt-4" Variant="Variant.Filled">
            @_syncError
        </MudAlert>
    }
</MudPaper>

<MudCard Elevation="1">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.subtitle1">Connection Details</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent Class="pt-0">
        <MudList T="string" Dense="true">
            <MudListItem Icon="@Icons.Material.Filled.AccessTime">
                <ChildContent>
                    Last Sync
                </ChildContent>
            </MudListItem>
            <MudText Typo="Typo.caption" Class="opacity-60 px-12 pb-2">
                @(WrenchWise.LastSyncUtc?.ToLocalTime().ToString("g") ?? "Never")
            </MudText>

            <MudListItem Icon="@Icons.Material.Filled.CloudQueue">
                <ChildContent>
                    Status
                </ChildContent>
            </MudListItem>
            <div class="px-12 pb-2">
                @if (WrenchWise.PendingSyncCount == 0)
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text">Up to date</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Text">Offline Changes</MudChip>
                }
            </div>
        </MudList>

        <MudDivider Class="my-2" />
        
        <MudText Typo="Typo.caption" Class="opacity-60 px-4 d-block mb-4">
            Running offline-first. To configure your server credentials, update Settings.
        </MudText>

        <div class="px-4 pb-2">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Size="Size.Small"
                       Href="settings"
                       FullWidth="true"
                       Class="rounded-pill">
                View Settings
            </MudButton>
        </div>
    </MudCardContent>
</MudCard>

@code {
    private bool _isSyncing;
    private string _syncError = "";

    protected override async Task OnInitializedAsync()
    {
        await WrenchWise.InitializeAsync();
        WrenchWise.Changed += HandleChanged;
    }

    private async Task AttemptSyncAsync()
    {
        _isSyncing = true;
        _syncError = "";
        StateHasChanged();

        try
        {
            await WrenchWise.SyncNowAsync();
        }
        catch(Exception ex)
        {
            _syncError = ex.Message;
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private void HandleChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => WrenchWise.Changed -= HandleChanged;
}
