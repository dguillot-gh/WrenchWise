@page "/fuel"
@implements IDisposable
@inject WrenchWiseService WrenchWise
@inject ISnackbar Snackbar

<PageTitle>Fuel Logs</PageTitle>

<div class="d-flex align-center justify-space-between mb-4">
    <MudText Typo="Typo.h4">Fuel Logs</MudText>
    @if (WrenchWise.Vehicles.Count > 0)
    {
        <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="AddNewRecord" Label="Add New" />
    }
</div>

@if (WrenchWise.Vehicles.Count == 0)
{
    <MudPaper Class="pa-8 d-flex flex-column align-center justify-center mud-text-secondary" Elevation="0" Outlined="true">
        <MudIcon Icon="@Icons.Material.Filled.LocalGasStation" Size="Size.Large" Class="mb-4 opacity-20" Style="font-size: 4rem;" />
        <MudText Typo="Typo.h6">No Vehicles Found</MudText>
        <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-4">Please add a vehicle first to start logging fuel.</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="vehicles">Go to Vehicles</MudButton>
    </MudPaper>
}
else
{
    <MudCollapse Expanded="_showForm">
        <MudCard Elevation="4" Class="mb-6 border-l-4 border-info">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Info" Variant="Variant.Filled"><MudIcon Icon="@Icons.Material.Filled.LocalGasStation" /></MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@(_isEditing ? "Edit Fuel Entry" : "New Fuel Entry")</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="ToggleForm" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <EditForm Model="_record" OnValidSubmit="SaveFuelAsync">
                    <DataAnnotationsValidator />
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudSelect T="Guid" Label="Vehicle" @bind-Value="_record.VehicleId" Variant="Variant.Outlined" Margin="Margin.Dense">
                                @foreach (var vehicle in WrenchWise.Vehicles)
                                {
                                    <MudSelectItem Value="@vehicle.Id">@vehicle.Nickname</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudDatePicker Label="Date" @bind-Date="_fillDate" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudNumericField T="double" Label="Trip Miles" @bind-Value="_record.TripMiles" Variant="Variant.Outlined" Margin="Margin.Dense" Format="F1" />
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudNumericField T="decimal" Label="Gallons" @bind-Value="_record.Gallons" Variant="Variant.Outlined" Margin="Margin.Dense" Format="F2" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudNumericField T="decimal" Label="Total Cost" @bind-Value="_record.TotalCost" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
                        </MudItem>
                        <MudItem xs="12" Class="d-flex align-center mt-n1 mb-n2">
                            <MudCheckBox T="bool" @bind-Value="_record.FullTank" Label="Full Tank (Used for MPG calc)" Color="Color.Primary" />
                        </MudItem>

                        <MudItem xs="12" Class="d-flex justify-end gap-2 mt-2">
                            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="ToggleForm">Cancel</MudButton>
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">Save Entry</MudButton>
                        </MudItem>
                    </MudGrid>
                </EditForm>
            </MudCardContent>
        </MudCard>
    </MudCollapse>

    @if (_ocrFuelId != Guid.Empty)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4 pa-4">
            <MudText Typo="Typo.subtitle2">Receipt OCR Hints</MudText>
            <MudTextField @bind-Value="_ocrText" Lines="3" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" Placeholder="Detected text from receipt..." />
            <div class="d-flex justify-end gap-2 mt-2">
                <MudButton OnClick="CancelOcr" Variant="Variant.Text">Cancel</MudButton>
                <MudButton OnClick="SaveOcrTextAsync" Variant="Variant.Filled" Color="Color.Primary">Apply Hints</MudButton>
            </div>
        </MudAlert>
    }

    @if (WrenchWise.FuelRecords.Count == 0)
    {
        <MudPaper Class="pa-8 d-flex flex-column align-center justify-center opacity-40" Elevation="0" Outlined="true">
            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Style="font-size: 3rem;" />
            <MudText Typo="Typo.body1">No Fuel Logs</MudText>
        </MudPaper>
    }
    else
    {
        <MudStack Spacing="3">
            @foreach (var record in WrenchWise.FuelRecords.OrderByDescending(x => x.FillDate))
            {
                <MudCard Elevation="2" Class="rounded-lg">
                    <MudCardHeader Class="pb-0">
                        <CardHeaderAvatar>
                            <MudAvatar Color="Color.Info" Variant="Variant.Text" Size="Size.Small"><MudIcon Icon="@Icons.Material.Filled.LocalGasStation" /></MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.body1" Color="Color.Info"><b>@record.TotalCost.ToString("C")</b></MudText>
                                <MudText Typo="Typo.caption" Class="opacity-60">@record.FillDate.ToString("MMM d, yyyy")</MudText>
                            </div>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomRight">
                                <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="() => EditFuelRecord(record)">Edit</MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.PhotoCamera" OnClick="() => AttachReceiptAsync(record.Id)">Attach Receipt</MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Description" OnClick="() => EditOcr(record)">Receipt OCR</MudMenuItem>
                                <MudDivider />
                                <MudMenuItem Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="() => WrenchWise.DeleteFuelRecordAsync(record.Id)">Delete</MudMenuItem>
                            </MudMenu>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent Class="pt-2">
                        <div class="d-flex align-center gap-4">
                            <div class="d-flex align-center gap-1 opacity-80">
                                <MudIcon Icon="@Icons.Material.Filled.WaterDrop" Size="Size.Small" />
                                <MudText Typo="Typo.body2">@record.Gallons gal</MudText>
                            </div>

                            @{
                                var previous = WrenchWise.FuelRecords
                                    .Where(x => x.VehicleId == record.VehicleId && x.FullTank && x.Odometer < record.Odometer)
                                    .OrderByDescending(x => x.Odometer)
                                    .FirstOrDefault();

                                double milesDriven = record.TripMiles > 0 
                                    ? record.TripMiles 
                                    : (previous != null ? (record.Odometer - previous.Odometer) : 0);

                                if (milesDriven > 0 && record.Gallons > 0 && record.FullTank)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.AutoGraph">
                                        @((milesDriven / (double)record.Gallons).ToString("0.0")) MPG
                                    </MudChip>
                                }
                            }
                        </div>

                        <div class="d-flex justify-space-between align-center mt-3">
                            @{
                                var vColorFuel = WrenchWise.Vehicles.FirstOrDefault(v => v.Id == record.VehicleId)?.ColorHex ?? "var(--mud-palette-primary)";
                            }
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.DirectionsCar" Style="@($"color: {vColorFuel}; border-color: {vColorFuel};")">
                                @FindVehicle(record.VehicleId)
                            </MudChip>
                            @if (milesDriven > 0)
                            {
                                <MudText Typo="Typo.caption" Class="opacity-60">@milesDriven.ToString("N1") miles traveled</MudText>
                            }
                        </div>
                    </MudCardContent>
                </MudCard>
            }
        </MudStack>
    }
}

<style>
    .border-l-4 { border-left-width: 4px !important; border-left-style: solid !important; }
    .border-info { border-left-color: var(--mud-palette-info) !important; }
</style>

@code {
    private FuelRecord _record = new();
    private DateTime? _fillDate = DateTime.Today;
    private Guid _ocrFuelId;
    private string _ocrText = string.Empty;
    private bool _showForm = false;
    private bool _isEditing = false;

    protected override async Task OnInitializedAsync()
    {
        await WrenchWise.InitializeAsync();
        WrenchWise.Changed += HandleChanged;
        ResetRecord();
    }

    private void AddNewRecord()
    {
        _isEditing = false;
        ResetRecord();
        _showForm = true;
    }

    private void ToggleForm()
    {
        _showForm = !_showForm;
        if (!_showForm) 
        {
            ResetRecord();
            _isEditing = false;
        }
    }

    private async Task SaveFuelAsync()
    {
        if (WrenchWise.Vehicles.Count == 0 || _record.Gallons <= 0)
        {
            return;
        }

        _record.FillDate = DateOnly.FromDateTime(_fillDate ?? DateTime.Today);

        // Auto-calculate the global vehicle Odometer from Trip Miles so metrics don't break
        if (!_isEditing)
        {
            _record.Odometer = WrenchWise.GetSuggestedOdometer(_record.VehicleId) + (int)Math.Round(_record.TripMiles);
        }
        else
        {
            // If editing, they might have changed trip distance. Recalculate roughly based on an old base or leave it.
            // But since they can't see/edit odometer anymore, recalculating it cleanly prevents weird jumps.
            var existingRecord = WrenchWise.FuelRecords.FirstOrDefault(x => x.Id == _record.Id);
            if (existingRecord != null)
            {
                var baseOdo = existingRecord.Odometer - (int)Math.Round(existingRecord.TripMiles);
                _record.Odometer = baseOdo + (int)Math.Round(_record.TripMiles);
            }
        }

        if (_isEditing)
        {
            await WrenchWise.UpdateFuelRecordAsync(_record);
            Snackbar.Add($"Fuel entry updated for {FindVehicle(_record.VehicleId)}", Severity.Success);
        }
        else
        {
            await WrenchWise.AddFuelRecordAsync(_record);
            Snackbar.Add($"Fuel entry saved for {FindVehicle(_record.VehicleId)}", Severity.Success);
        }

        ResetRecord();
        _showForm = false;
        _isEditing = false;
    }

    private async Task AttachReceiptAsync(Guid fuelId)
    {
        await WrenchWise.AttachReceiptPhotoAsync(fuelId);
    }

    private void EditFuelRecord(FuelRecord record)
    {
        _record = new FuelRecord
        {
            Id = record.Id,
            VehicleId = record.VehicleId,
            FillDate = record.FillDate,
            Odometer = record.Odometer,
            TripMiles = record.TripMiles,
            Gallons = record.Gallons,
            TotalCost = record.TotalCost,
            FullTank = record.FullTank,
            Station = record.Station,
            FuelGrade = record.FuelGrade,
            EthanolPercent = record.EthanolPercent,
            AdditiveNotes = record.AdditiveNotes,
            ReceiptImagePath = record.ReceiptImagePath,
            ReceiptOcrText = record.ReceiptOcrText
        };
        _fillDate = record.FillDate.ToDateTime(TimeOnly.MinValue);
        _isEditing = true;
        _showForm = true;
    }

    private void EditOcr(FuelRecord record)
    {
        _ocrFuelId = record.Id;
        _ocrText = record.ReceiptOcrText;
    }

    private async Task SaveOcrTextAsync()
    {
        if (_ocrFuelId == Guid.Empty) return;

        await WrenchWise.ApplyReceiptTextAsync(_ocrFuelId, _ocrText);
        Snackbar.Add("OCR hints applied", Severity.Info);
        CancelOcr();
    }

    private void CancelOcr()
    {
        _ocrFuelId = Guid.Empty;
        _ocrText = string.Empty;
    }

    private void ResetRecord()
    {
        _record = new FuelRecord
        {
            VehicleId = WrenchWise.ActiveVehicleId != Guid.Empty
                ? WrenchWise.ActiveVehicleId
                : WrenchWise.Vehicles.FirstOrDefault()?.Id ?? Guid.Empty,
            FullTank = true,
            FuelGrade = "Regular",
            EthanolPercent = 10
        };
        _fillDate = DateTime.Today;
    }

    private string FindVehicle(Guid vehicleId) => WrenchWise.Vehicles.FirstOrDefault(v => v.Id == vehicleId)?.Nickname ?? "Unknown";

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => WrenchWise.Changed -= HandleChanged;
}
