@page "/"
@implements IDisposable
@inject WrenchWiseService WrenchWise
@inject NavigationManager Nav

<PageTitle>Dashboard</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true" Class="mt-2 mb-1 fw-bold">My Garage</MudText>
<MudText Typo="Typo.body2" Class="opacity-60 mb-5">Your vehicles at a glance.</MudText>

@if (WrenchWise.ActiveTrip != null)
{
    var tripSpan = (DateOnly.FromDateTime(DateTime.Today).DayNumber - WrenchWise.ActiveTrip.StartDate.DayNumber) + 1;
    <MudAlert Severity="Severity.Normal" Variant="Variant.Filled" Class="mb-5 rounded-lg" Style="background-color: var(--mud-palette-primary-dark);">
        <div class="d-flex align-center justify-space-between w-100">
            <div class="d-flex align-center gap-3">
                <MudIcon Icon="@Icons.Material.Filled.Map" Color="Color.Surface" />
                <div>
                    <MudText Typo="Typo.subtitle2"><b>Active Trip: @WrenchWise.ActiveTrip.TripName</b></MudText>
                    <MudText Typo="Typo.caption" Class="opacity-70">Started at @WrenchWise.ActiveTrip.StartOdometer.ToString("N0") mi • Day @tripSpan</MudText>
                </div>
            </div>
        </div>
    </MudAlert>
}

@if (!_ready)
{
    <MudGrid Spacing="2">
        @for (int i = 0; i < 4; i++)
        {
            <MudItem xs="6" sm="3">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="80px" />
            </MudItem>
        }
    </MudGrid>
}
else if (WrenchWise.Vehicles.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="mt-4">
        No vehicles yet. Add one in the <MudLink href="vehicles" Color="Color.Inherit"><b>Vehicles tab</b></MudLink>.
    </MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="2" Class="pa-3 d-flex flex-column align-center justify-center border-l-4 border-primary">
                <MudIcon Icon="@Icons.Material.Filled.DirectionsCar" Color="Color.Primary" Size="Size.Small" Class="mb-1" />
                <MudText Typo="Typo.h6" Color="Color.Primary"><b>@WrenchWise.Vehicles.Count</b></MudText>
                <MudText Typo="Typo.caption" Class="opacity-60 uppercase font-weight-bold" Style="font-size: 0.65rem;">Vehicles</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="2" Class="pa-3 d-flex flex-column align-center justify-center border-l-4 border-warning">
                <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Warning" Size="Size.Small" Class="mb-1" />
                <MudText Typo="Typo.h6" Color="Color.Warning"><b>@WrenchWise.MaintenanceRecords.Count</b></MudText>
                <MudText Typo="Typo.caption" Class="opacity-60 uppercase font-weight-bold" Style="font-size: 0.65rem;">Services</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="2" Class="pa-3 d-flex flex-column align-center justify-center border-l-4 border-info">
                <MudIcon Icon="@Icons.Material.Filled.LocalGasStation" Color="Color.Info" Size="Size.Small" Class="mb-1" />
                <MudText Typo="Typo.h6" Color="Color.Info"><b>@WrenchWise.FuelRecords.Count</b></MudText>
                <MudText Typo="Typo.caption" Class="opacity-60 uppercase font-weight-bold" Style="font-size: 0.65rem;">Fuel Logs</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="2" Class="pa-3 d-flex flex-column align-center justify-center border-l-4 border-error">
                <MudIcon Icon="@Icons.Material.Filled.Sync" Color="Color.Error" Size="Size.Small" Class="mb-1" />
                <MudText Typo="Typo.h6" Color="Color.Error"><b>@WrenchWise.PendingSyncCount</b></MudText>
                <MudText Typo="Typo.caption" Class="opacity-60 uppercase font-weight-bold" Style="font-size: 0.65rem;">Pending</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.subtitle1" Class="fw-bold mb-3">Your Vehicles</MudText>

    @foreach (var vehicle in WrenchWise.Vehicles.OrderByDescending(x => x.UpdatedUtc))
    {
        <MudCard Elevation="2" Class="mb-4 rounded-lg overflow-hidden border-solid border-1 mud-border-lines-default" Style="@($"cursor: pointer; border-left-width: 4px; border-left-color: {vehicle.ColorHex} !important;")" @onclick="@(() => GoToDetails(vehicle.Id))">
            <MudCardHeader Class="pb-1">
                <CardHeaderAvatar>
                    <MudAvatar Variant="Variant.Filled" Size="Size.Medium" Style="@($"background-color: {vehicle.ColorHex} !important; color: white !important;")">@vehicle.Nickname[0]</MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.body2"><b>@vehicle.Nickname</b></MudText>
                    <MudText Typo="Typo.caption" Class="opacity-60">@vehicle.Year @vehicle.Make @vehicle.Model</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent Class="py-0 px-4">
                <div class="d-flex justify-space-between py-2 border-b-1 mud-border-lines-default opacity-80">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.Speed" Size="Size.Small" />
                        <MudText Typo="Typo.body2">Odometer</MudText>
                    </div>
                    <MudText Typo="Typo.body2"><b>@vehicle.CurrentOdometer.ToString("N0") miles</b></MudText>
                </div>
                <div class="d-flex justify-space-between py-2 border-b-1 mud-border-lines-default opacity-80">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.Payments" Size="Size.Small" />
                        <MudText Typo="Typo.body2">Total Spending</MudText>
                    </div>
                    <MudText Typo="Typo.body2"><b>@WrenchWise.GetTotalSpent(vehicle.Id).ToString("C")</b></MudText>
                </div>
                <div class="d-flex justify-space-between py-2 opacity-80">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.ShowChart" Size="Size.Small" />
                        <MudText Typo="Typo.body2">Average MPG</MudText>
                    </div>
                    <MudText Typo="Typo.body2"><b>@WrenchWise.GetAverageMpg(vehicle.Id)</b></MudText>
                </div>

                @{
                    var dueReminders = WrenchWise.ServiceReminders.Where(r => r.VehicleId == vehicle.Id && WrenchWise.IsReminderDue(r)).ToList();
                    var expiredDocs = WrenchWise.VehicleDocuments.Where(d => d.VehicleId == vehicle.Id && WrenchWise.IsDocumentExpired(d)).ToList();
                    var expiringDocs = WrenchWise.VehicleDocuments.Where(d => d.VehicleId == vehicle.Id && WrenchWise.IsDocumentExpiring(d)).ToList();

                    if (expiredDocs.Any())
                    {
                        <div class="d-flex align-center gap-2 py-2 mt-1 px-3 rounded-lg mud-palette-error opacity-80" style="background-color: var(--mud-palette-error-hover);">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Small" />
                            <MudText Typo="Typo.caption" Color="Color.Error"><b>Expired Documents:</b> @string.Join(", ", expiredDocs.Select(d => d.DocumentType))</MudText>
                        </div>
                    }
                    else if (expiringDocs.Any())
                    {
                        <div class="d-flex align-center gap-2 py-2 mt-1 px-3 rounded-lg mud-palette-warning opacity-80" style="background-color: var(--mud-palette-warning-hover);">
                            <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Warning" Size="Size.Small" />
                            <MudText Typo="Typo.caption" Color="Color.Warning"><b>Expiring Documents:</b> @string.Join(", ", expiringDocs.Select(d => d.DocumentType))</MudText>
                        </div>
                    }

                    if (dueReminders.Any())
                    {
                        <div @onclick="@(() => Nav.NavigateTo("/reminders"))" @onclick:stopPropagation="true" class="d-flex align-center gap-2 py-2 mt-1 px-3 rounded-lg mud-palette-error opacity-80" style="background-color: var(--mud-palette-error-hover); cursor: pointer;">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Small" />
                            <MudText Typo="Typo.caption" Color="Color.Error"><b>@dueReminders.Count Service Due:</b> @string.Join(", ", dueReminders.Select(r => r.Title))</MudText>
                        </div>
                    }
                }
            </MudCardContent>
            <MudCardActions Class="px-4 pb-2 gap-2">
                <MudButton OnClick="@(() => GoToDetails(vehicle.Id))" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Launch" Class="rounded-pill mt-1">Details</MudButton>
                <div @onclick:stopPropagation="true" class="d-inline-block">
                    <MudButton OnClick="@(() => ExportVehicleHistoryAsync(vehicle.Id))" Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" StartIcon="@Icons.Material.Filled.Download" Class="rounded-pill mt-1">Export</MudButton>
                </div>
            </MudCardActions>
        </MudCard>
    }
}

<MudMenu ActivationEvent="MouseEvent.LeftClick" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.BottomRight" ListClass="py-2" PopoverClass="mb-4 mr-4">
    <ActivatorContent>
        <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Class="mud-elevation-4" Style="position: fixed; bottom: 24px; right: 24px; z-index: 100;" />
    </ActivatorContent>
    <ChildContent>
        <MudMenuItem Href="/fuel" Icon="@Icons.Material.Filled.LocalGasStation" IconColor="Color.Info" Class="px-4 py-2">Log Fuel</MudMenuItem>
        <MudMenuItem Href="/maintenance" Icon="@Icons.Material.Filled.Build" IconColor="Color.Warning" Class="px-4 py-2">Log Service</MudMenuItem>
        <MudMenuItem Href="/tires" Icon="@Icons.Material.Filled.Settings" IconColor="Color.Primary" Class="px-4 py-2">Add Tires</MudMenuItem>
    </ChildContent>
</MudMenu>

<style>
    .border-l-4 { border-left-width: 4px !important; border-left-style: solid !important; }
    .border-primary { border-left-color: var(--mud-palette-primary) !important; }
    .border-warning { border-left-color: var(--mud-palette-warning) !important; }
    .border-info { border-left-color: var(--mud-palette-info) !important; }
    .border-error { border-left-color: var(--mud-palette-error) !important; }
    .uppercase { text-transform: uppercase; }
</style>

@code {
    private bool _ready;

    protected override async Task OnInitializedAsync()
    {
        await WrenchWise.InitializeAsync();
        WrenchWise.Changed += HandleChanged;
        _ready = true;
    }

    private void HandleChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task GoToDetails(Guid vehicleId)
    {
        await WrenchWise.SetActiveVehicleAsync(vehicleId);
        Nav.NavigateTo("/timeline");
    }

    private async Task ExportVehicleHistoryAsync(Guid vehicleId)
    {
        var filePath = await WrenchWise.GenerateVehicleHistoryCsvAsync(vehicleId);
        if (!string.IsNullOrEmpty(filePath))
        {
            await Microsoft.Maui.ApplicationModel.DataTransfer.Share.Default.RequestAsync(new Microsoft.Maui.ApplicationModel.DataTransfer.ShareFileRequest
            {
                Title = "Vehicle History",
                File = new Microsoft.Maui.ApplicationModel.DataTransfer.ShareFile(filePath)
            });
        }
    }

    public void Dispose()
    {
        WrenchWise.Changed -= HandleChanged;
    }
}
