@page "/tires"
@implements IDisposable
@inject WrenchWiseService WrenchWise
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Tires</PageTitle>

<div class="d-flex align-center justify-space-between mb-4">
    <MudText Typo="Typo.h5">Tire Tracking</MudText>
    @if (WrenchWise.Vehicles.Count > 0)
    {
        <MudIconButton Icon="@Icons.Material.Filled.Add"
                       Color="Color.Primary"
                       OnClick="ToggleForm"
                       Variant="Variant.Filled"
                       Size="Size.Small" />
    }
</div>

@if (WrenchWise.Vehicles.Count == 0)
{
    <MudStack AlignItems="AlignItems.Center" Class="mt-12 opacity-60">
        <MudIcon Icon="@Icons.Material.Filled.DirectionsCar" Size="Size.Large" />
        <MudText Typo="Typo.h6">No Vehicles Found</MudText>
        <MudText Typo="Typo.body2">Please add a vehicle first to start logging tire sets.</MudText>
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="vehicles">Go to Vehicles</MudButton>
    </MudStack>
}
else
{
    @if (_showForm)
    {
        <MudCard Elevation="2" Class="mb-6 border-l-4 border-solid" Style="border-left-color: var(--mud-palette-primary);">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.subtitle1">@(_isEditing ? "Edit Tire Set" : "New Tire Set")</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="ToggleForm" Size="Size.Small" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <MudSelect T="Guid" Label="Vehicle" @bind-Value="_record.VehicleId" @bind-Value:after="ApplySuggestedOdometer" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                            @foreach (var vehicle in WrenchWise.Vehicles)
                            {
                                <MudSelectItem Value="@vehicle.Id">@vehicle.Nickname</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Brand & Model" @bind-Value="_record.BrandModel" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="e.g. Michelin Defender" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="Position / Info" @bind-Value="_record.Position" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="e.g. Front Right, Full Set" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField Label="Total Cost" @bind-Value="_record.PurchaseCost" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Label="Install Date" @bind-Date="_installDate" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField Label="Install Odometer" @bind-Value="_record.InstalledOdometer" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" />
                    </MudItem>
                    <MudItem xs="12" Class="d-flex justify-end">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveRecordAsync" Class="rounded-pill px-6">Save Tires</MudButton>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    }

    @if (WrenchWise.TireRecords.Count == 0)
    {
        <MudStack AlignItems="AlignItems.Center" Class="mt-12 opacity-60">
            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" />
            <MudText Typo="Typo.h6">No Tires Tracked</MudText>
            <MudText Typo="Typo.body2">Add a new set of tires to start tracking their lifespan.</MudText>
        </MudStack>
    }
    else
    {
        <MudStack Spacing="3">
            @foreach (var set in WrenchWise.TireRecords.OrderByDescending(x => x.InstalledDate))
            {
                var vehicle = WrenchWise.Vehicles.FirstOrDefault(v => v.Id == set.VehicleId);
                var currentOdo = vehicle?.CurrentOdometer ?? 0;
                var milesDriven = Math.Max(0, currentOdo - set.InstalledOdometer);
                
                <MudCard Elevation="1">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="Color.Primary" Variant="Variant.Text">
                                <MudIcon Icon="@Icons.Material.Filled.Settings" />
                            </MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">@set.BrandModel</MudText>
                            <MudText Typo="Typo.caption" Class="opacity-60">@set.Position</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIconButton Icon="@(_expandedTireId == set.Id ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" OnClick="@(() => ToggleExpand(set.Id))" />
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
                                <MudMenuItem OnClick="() => EditRecord(set)" Icon="@Icons.Material.Filled.Edit">Edit</MudMenuItem>
                                <MudMenuItem OnClick="() => WrenchWise.DeleteTireRecordAsync(set.Id)" IconColor="Color.Error" Icon="@Icons.Material.Filled.Delete">Delete</MudMenuItem>
                            </MudMenu>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent Class="pt-0">
                        <div class="d-flex justify-space-between align-center mb-2">
                            <MudText Typo="Typo.body2" Class="opacity-70">Distance driven:</MudText>
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary">@milesDriven.ToString("N0") mi</MudText>
                        </div>
                        <MudDivider Class="my-2" />
                        <div class="d-flex justify-space-between align-center">
                            @{
                                var vColorTires = vehicle?.ColorHex ?? "var(--mud-palette-primary)";
                            }
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.DirectionsCar" Style="@($"color: {vColorTires}; border-color: {vColorTires};")">
                                @(vehicle?.Nickname ?? "Unknown")
                            </MudChip>
                            <MudText Typo="Typo.caption" Class="opacity-50">
                                @set.InstalledDate.ToString("MMM yyyy")
                            </MudText>
                        </div>

                        <MudCollapse Expanded="@(_expandedTireId == set.Id)">
                            <MudDivider Class="my-3" />
                            <div class="d-flex justify-space-between align-center mb-2">
                                <MudText Typo="Typo.subtitle2">Rotations</MudText>
                                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="@(() => PromptAddRotation(set))" StartIcon="@Icons.Material.Filled.Add">Add Rotation</MudButton>
                            </div>
                            
                            @if (_loggingRotationId == set.Id)
                            {
                                <div class="d-flex align-center gap-2 mb-3">
                                    <MudNumericField @bind-Value="_newRotationOdo" Margin="Margin.Dense" Variant="Variant.Outlined" Label="Odometer" HideSpinButtons="true" />
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="@(() => SaveRotationAsync(set))">Save</MudButton>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => _loggingRotationId = null)" />
                                </div>
                            }

                            @if (set.Rotations == null || set.Rotations.Count == 0)
                            {
                                <MudText Typo="Typo.caption" Class="opacity-60 mb-2 d-block">No rotations logged yet.</MudText>
                            }
                            else
                            {
                                <MudStack Spacing="1" Class="mb-2">
                                    @foreach (var rot in set.Rotations.OrderByDescending(x => x.Odometer))
                                    {
                                        <div class="d-flex justify-space-between align-center py-1 border-b-1 mud-border-lines-default">
                                            <div class="d-flex align-center gap-2">
                                                <MudIcon Icon="@Icons.Material.Filled.RotateRight" Size="Size.Small" Class="opacity-60" />
                                                <MudText Typo="Typo.body2">@rot.Odometer.ToString("N0") mi</MudText>
                                            </div>
                                            <MudText Typo="Typo.caption" Class="opacity-60">@rot.Date.ToString("MMM d, yyyy")</MudText>
                                        </div>
                                    }
                                </MudStack>
                            }
                        </MudCollapse>
                    </MudCardContent>
                </MudCard>
            }
        </MudStack>
    }
}

@code {
    private TireRecord _record = new();
    private DateTime? _installDate = DateTime.Today;
    private bool _showForm = false;
    private bool _isEditing = false;
    private Guid? _expandedTireId;
    
    private Guid? _loggingRotationId;
    private int _newRotationOdo;

    protected override async Task OnInitializedAsync()
    {
        await WrenchWise.InitializeAsync();
        WrenchWise.Changed += HandleChanged;
        ResetRecord();
    }

    private void ToggleExpand(Guid tireId)
    {
        _expandedTireId = _expandedTireId == tireId ? null : tireId;
        _loggingRotationId = null;
    }

    private void ToggleForm()
    {
        _showForm = !_showForm;
        if (!_showForm) 
        {
            ResetRecord();
            _isEditing = false;
        }
    }

    private void ResetRecord()
    {
        _record = new TireRecord
        {
            VehicleId = WrenchWise.ActiveVehicleId != Guid.Empty
                ? WrenchWise.ActiveVehicleId
                : WrenchWise.Vehicles.FirstOrDefault()?.Id ?? Guid.Empty,
            Position = "Full Set"
        };
        _installDate = DateTime.Today;

        if (_record.VehicleId != Guid.Empty)
        {
            _record.InstalledOdometer = WrenchWise.GetSuggestedOdometer(_record.VehicleId);
        }
    }

    private void ApplySuggestedOdometer()
    {
        if (_record.VehicleId != Guid.Empty)
        {
            _record.InstalledOdometer = WrenchWise.GetSuggestedOdometer(_record.VehicleId);
        }
    }

    private async Task EditRecord(TireRecord record)
    {
        _showForm = false;
        await InvokeAsync(StateHasChanged);

        _record = new TireRecord
        {
            Id = record.Id,
            VehicleId = record.VehicleId,
            Position = record.Position,
            BrandModel = record.BrandModel,
            InstalledDate = record.InstalledDate,
            InstalledOdometer = record.InstalledOdometer,
            RemovedDate = record.RemovedDate,
            RemovedOdometer = record.RemovedOdometer,
            PurchaseCost = record.PurchaseCost,
            Notes = record.Notes,
            Rotations = record.Rotations?.Select(r => new TireRotation { Id = r.Id, Date = r.Date, Odometer = r.Odometer }).ToList() ?? new()
        };
        _installDate = record.InstalledDate.ToDateTime(TimeOnly.MinValue);
        _isEditing = true;
        _showForm = true;
        await JS.InvokeVoidAsync("eval", "document.querySelector('.mud-main-content')?.scrollTo(0,0)");
    }

    private async Task SaveRecordAsync()
    {
        if (WrenchWise.Vehicles.Count == 0 || string.IsNullOrWhiteSpace(_record.BrandModel))
        {
            Snackbar.Add("Please enter the brand and model.", Severity.Warning);
            return;
        }

        _record.InstalledDate = DateOnly.FromDateTime(_installDate ?? DateTime.Today);
        
        if (_isEditing)
        {
            await WrenchWise.UpdateTireRecordAsync(_record);
            Snackbar.Add("Tire set updated successfully!", Severity.Success);
        }
        else
        {
            await WrenchWise.AddTireRecordAsync(_record);
            Snackbar.Add("Tire set added successfully!", Severity.Success);
        }
        
        ResetRecord();
        _showForm = false;
        _isEditing = false;
    }

    private void PromptAddRotation(TireRecord set)
    {
        var v = WrenchWise.Vehicles.FirstOrDefault(x => x.Id == set.VehicleId);
        _newRotationOdo = v?.CurrentOdometer ?? set.InstalledOdometer;
        _loggingRotationId = set.Id;
    }

    private async Task SaveRotationAsync(TireRecord set)
    {
        if (set.Rotations == null)
            set.Rotations = new List<TireRotation>();

        set.Rotations.Add(new TireRotation
        {
            Date = DateOnly.FromDateTime(DateTime.Today),
            Odometer = _newRotationOdo
        });
        
        await WrenchWise.UpdateTireRecordAsync(set);
        _loggingRotationId = null;
        Snackbar.Add("Rotation logged!", Severity.Success);
    }

    private void HandleChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => WrenchWise.Changed -= HandleChanged;
}
