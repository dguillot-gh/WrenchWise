@page "/vehicles"
@implements IDisposable
@inject WrenchWiseService WrenchWise
@inject IDialogService DialogService

<PageTitle>Vehicles</PageTitle>

<div class="d-flex align-center justify-space-between mt-4 mb-8">
    <MudText Typo="Typo.h5" Class="fw-bold">Garage</MudText>
    <MudButton StartIcon="@Icons.Material.Filled.Add"
               Variant="Variant.Filled"
               Color="Color.Primary"
               OnClick="ToggleForm"
               Size="Size.Small">
        Add Vehicle
    </MudButton>
</div>

@if (_showForm)
{
    <MudCard Elevation="2" Class="mb-6 border-l-4 border-solid border-primary" Style="border-left-width: 6px;">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@(_editingId.HasValue ? "Edit Vehicle" : "New Vehicle")</MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="CancelEdit" />
            </CardHeaderActions>
        </MudCardHeader>
        <MudCardContent>
            <EditForm Model="_vehicle" OnValidSubmit="SaveVehicleAsync">
                <DataAnnotationsValidator />
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="5">
                        <MudTextField Label="Nickname" @bind-Value="_vehicle.Nickname"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Required="true" Placeholder="e.g. Daily Civic" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField Label="Odometer" @bind-Value="_vehicle.CurrentOdometer"
                                         Variant="Variant.Outlined" Margin="Margin.Dense"
                                         HideSpinButtons="true" Adornment="Adornment.End" AdornmentText="mi" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudColorPicker Label="Color Theme" @bind-Text="_vehicle.ColorHex" ColorPickerMode="ColorPickerMode.RGB" ColorPickerView="ColorPickerView.Palette" DisableAlpha="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudToggleIconButton @bind-Toggled="_showAdvanced"
                                             Icon="@Icons.Material.Filled.ExpandMore"
                                             ToggledIcon="@Icons.Material.Filled.ExpandLess" />
                        <MudText Typo="Typo.caption" Class="ml-2">@( _showAdvanced ? "Hide additional details" : "Add Make, Model, Year, VIN, notes")</MudText>
                    </MudItem>

                    @if (_showAdvanced)
                    {
                        <MudItem xs="4">
                            <MudNumericField Label="Year" @bind-Value="_vehicle.Year" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField Label="Make" @bind-Value="_vehicle.Make" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudTextField Label="Model" @bind-Value="_vehicle.Model" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField Label="VIN" @bind-Value="_vehicle.Vin" Variant="Variant.Outlined" Margin="Margin.Dense" Class="text-uppercase" HelperText="17-character VIN" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField Label="Notes" @bind-Value="_vehicle.Notes" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
                        </MudItem>
                    }

                    <MudItem xs="12" Class="d-flex justify-end gap-2 mt-4">
                        <MudButton OnClick="CancelEdit" Variant="Variant.Text">Cancel</MudButton>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">Save Vehicle</MudButton>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudCardContent>
    </MudCard>
}

@if (WrenchWise.Vehicles.Count == 0 && !_showForm)
{
    <MudStack AlignItems="AlignItems.Center" Class="mt-12 opacity-50">
        <MudIcon Icon="@Icons.Material.Filled.DirectionsCar" Size="Size.Large" Style="font-size: 5rem;" />
        <MudText Typo="Typo.h6">Your garage is empty</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ToggleForm">Add your first vehicle</MudButton>
    </MudStack>
}
else
{
    <MudGrid Spacing="4">
        @foreach (var vehicle in WrenchWise.Vehicles)
        {
            var isEditingThis = _editingId == vehicle.Id;
            var isActive = vehicle.Id == WrenchWise.ActiveVehicleId;

            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="isActive ? 4 : 1" Style="@($"border-left-width: 6px; border-left-style: solid; border-left-color: {vehicle.ColorHex} !important;")">
                    <MudCardHeader Class="pb-3">
                        <CardHeaderAvatar>
                            <MudAvatar Variant="Variant.Filled" Style="@($"background-color: {vehicle.ColorHex} !important; color: white !important; height:50px; width:50px;")">
                                <MudIcon Icon="@Icons.Material.Filled.DirectionsCar" />
                            </MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.body1" Class="fw-bold">@vehicle.Nickname</MudText>
                            <MudText Typo="Typo.caption">
                                @(string.IsNullOrWhiteSpace($"{vehicle.Year} {vehicle.Make} {vehicle.Model}")
                                    ? "No details provided"
                                    : $"{vehicle.Year} {vehicle.Make} {vehicle.Model}")
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="() => EditVehicle(vehicle)">Edit</MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.CheckCircle" OnClick="() => WrenchWise.SetActiveVehicleAsync(vehicle.Id)" Disabled="isActive">Set Active</MudMenuItem>
                                <MudDivider />
                                <MudMenuItem Icon="@Icons.Material.Filled.Delete" OnClick="() => DeleteVehicleAsync(vehicle.Id)" Class="text-danger">Delete</MudMenuItem>
                            </MudMenu>
                        </CardHeaderActions>
                    </MudCardHeader>

                    <MudCardContent Class="pt-0 px-5 pb-5">
                        <MudStack Row="true" Spacing="3">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.Speed" Color="Color.Default">
                                @vehicle.CurrentOdometer.ToString("N0") mi
                            </MudChip>
                            @if (!string.IsNullOrWhiteSpace(vehicle.Vin))
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.Fingerprint" Color="Color.Default">
                                    VIN: @(vehicle.Vin.Length > 8 ? vehicle.Vin.Substring(0, 8) + "..." : vehicle.Vin)
                                </MudChip>
                            }
                        </MudStack>

                        @if (!string.IsNullOrWhiteSpace(vehicle.Notes))
                        {
                            <MudText Typo="Typo.body2" Class="mt-2 text-muted italic">@vehicle.Notes</MudText>
                        }
                    </MudCardContent>

                    @if (isActive)
                    {
                        <MudCardActions>
                            <MudChip T="string" Label="true" Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled">ACTIVE VEHICLE</MudChip>
                        </MudCardActions>
                    }
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private Vehicle _vehicle = new();
    private bool _showForm = false;
    private bool _showAdvanced = false;
    private Guid? _editingId;

    protected override async Task OnInitializedAsync()
    {
        await WrenchWise.InitializeAsync();
        WrenchWise.Changed += HandleChanged;
    }

    private void ToggleForm()
    {
        if (_showForm)
        {
            CancelEdit();
        }
        else
        {
            _showForm = true;
            _vehicle = new Vehicle();
            _editingId = null;
        }
    }

    private async Task SaveVehicleAsync()
    {
        if (_editingId.HasValue)
        {
            await WrenchWise.UpdateVehicleAsync(_vehicle);
        }
        else
        {
            await WrenchWise.AddVehicleAsync(_vehicle);
        }

        CancelEdit();
    }

    private void EditVehicle(Vehicle v)
    {
        _vehicle = new Vehicle
        {
            Id = v.Id,
            Nickname = v.Nickname,
            Make = v.Make,
            Model = v.Model,
            Year = v.Year,
            Vin = v.Vin,
            Notes = v.Notes,
            ColorHex = v.ColorHex,
            CurrentOdometer = v.CurrentOdometer
        };
        _editingId = v.Id;
        _showForm = true;
        _showAdvanced = !string.IsNullOrWhiteSpace(v.Vin) || v.Year > 0 || !string.IsNullOrWhiteSpace(v.Notes);
        StateHasChanged();
    }

    private async Task DeleteVehicleAsync(Guid id)
    {
        var result = await DialogService.ShowAsync<MudMessageBox>("Delete Vehicle",
            new DialogParameters { ["Message"] = "Are you sure you want to remove this vehicle and all its associated logs?" });

        if (result != null)
        {
            await WrenchWise.RemoveVehicleAsync(id);
        }
    }

    private void CancelEdit()
    {
        _vehicle = new Vehicle();
        _editingId = null;
        _showForm = false;
        _showAdvanced = false;
    }

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => WrenchWise.Changed -= HandleChanged;
}
