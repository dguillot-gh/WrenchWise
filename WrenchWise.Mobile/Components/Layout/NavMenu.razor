@inject NavigationManager Nav

<MudPaper Elevation="4" Class="fixed-bottom-nav">
    <MudNavMenu Margin="Margin.Dense" Rounded="true">
        <div class="d-flex justify-space-around align-center py-3 px-2">
            <MudIconButton Icon="@Icons.Material.Filled.Home" Color="@GetColor("")" OnClick="@(() => Nav.NavigateTo(""))" />
            <MudIconButton Icon="@Icons.Material.Filled.Build" Color="@GetColor("maintenance")" OnClick="@(() => Nav.NavigateTo("maintenance"))" />

            <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Size="Size.Medium" OnClick="@(() => Nav.NavigateTo("quick-add"))" />

            <MudIconButton Icon="@Icons.Material.Filled.LocalGasStation" Color="@GetColor("fuel")" OnClick="@(() => Nav.NavigateTo("fuel"))" />

            <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter" Color="Color.Default">
                <MudMenuItem OnClick="@(() => Nav.NavigateTo("vehicles"))">Vehicles</MudMenuItem>
                <MudMenuItem OnClick="@(() => Nav.NavigateTo("trip-mode"))">Trip Mode</MudMenuItem>
                <MudMenuItem OnClick="@(() => Nav.NavigateTo("timeline"))">Timeline</MudMenuItem>
                <MudMenuItem OnClick="@(() => Nav.NavigateTo("tires"))">Tires</MudMenuItem>
                <MudMenuItem OnClick="@(() => Nav.NavigateTo("projects"))">Projects</MudMenuItem>
                <MudMenuItem OnClick="@(() => Nav.NavigateTo("documents"))">Vault</MudMenuItem>
                <MudMenuItem OnClick="@(() => Nav.NavigateTo("insights"))">Insights</MudMenuItem>
                <MudMenuItem OnClick="@(() => Nav.NavigateTo("reminders"))">Reminders</MudMenuItem>
                <MudMenuItem OnClick="@(() => Nav.NavigateTo("sync"))">Sync</MudMenuItem>
                <MudMenuItem OnClick="@(() => Nav.NavigateTo("settings"))">Settings</MudMenuItem>
            </MudMenu>
        </div>
    </MudNavMenu>
</MudPaper>

<style>
    .fixed-bottom-nav {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background-color: var(--mud-palette-surface);
        border-top: 1px solid var(--mud-palette-divider);
        padding-bottom: calc(env(safe-area-inset-bottom, 12px) + 20px) !important;
    }
</style>

@code {
    private Color GetColor(string path)
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        return relative == path ? Color.Primary : Color.Default;
    }
}


